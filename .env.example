# LINE Messaging API（https://developers.line.biz/ja/ で発行）
LINE_TOKEN=チャネルアクセストークン（長期）をここに貼る
LINE_USER_ID=送信先ユーザーID（Uxxxxxxx...）をここに貼る

# シグナル設定（変更任意）
# SIGNAL__PAIR=USDJPY=X
# SIGNAL__INTERVAL=1h
# SIGNAL__LOOKBACK_DAYS=60
# SIGNAL__EMA_SHORT=9
# SIGNAL__EMA_LONG=21
# SIGNAL__RSI_PERIOD=14
# SIGNAL__RSI_BUY_THRESHOLD=55.0
# SIGNAL__RSI_SELL_THRESHOLD=45.0
# SIGNAL__ADX_THRESHOLD=20.0

# スケジューラ（デフォルト: 60分ごと）
# SCHEDULER__INTERVAL_MINUTES=60
